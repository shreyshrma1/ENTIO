@prefix entio: <https://example.com/entio/simple#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

entio:Customer a rdfs:Class ;
  rdfs:label "Customer" .

entio:Account a rdfs:Class ;
  rdfs:label "Account" .

entio:ownsAccount a rdf:Property ;
  rdfs:label "owns account" .
