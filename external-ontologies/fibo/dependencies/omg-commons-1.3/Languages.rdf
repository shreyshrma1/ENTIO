		See https://opensource.org/licenses/MIT.</dct:license>
		<dct:references>BCP 47, Tags for Identifying Languages, see http://tools.ietf.org/html/bcp47</dct:references>
		<dct:references>ISO 639 Code for individual languages and language groups, Second edition, 2023-11</dct:references>
		<dct:references rdf:resource="http://purl.org/dc/terms/"/>
		<dct:references rdf:resource="http://www.w3.org/2004/02/skos/core#"/>
		<dct:title>Commons Languages Ontology</dct:title>
		<owl:imports rdf:resource="https://www.omg.org/spec/Commons/AnnotationVocabulary/"/>
		<owl:imports rdf:resource="https://www.omg.org/spec/Commons/CodesAndCodeSets/"/>
		<owl:imports rdf:resource="https://www.omg.org/spec/Commons/Collections/"/>
		<owl:imports rdf:resource="https://www.omg.org/spec/Commons/ContextualDesignators/"/>
		<owl:imports rdf:resource="https://www.omg.org/spec/Commons/Designators/"/>
		<owl:imports rdf:resource="https://www.omg.org/spec/Commons/Identifiers/"/>
		<owl:versionIRI rdf:resource="https://www.omg.org/spec/Commons/20250801/Languages/"/>
		<cmns-av:copyright>Copyright (c) 2015-2017 Unisys</cmns-av:copyright>
		<cmns-av:copyright>Copyright (c) 2015-2019 Adaptive, Inc.</cmns-av:copyright>
		<cmns-av:copyright>Copyright (c) 2015-2025 Object Management Group, Inc.</cmns-av:copyright>
		<cmns-av:copyright>Copyright (c) 2015-2025 Thematix Partners LLC</cmns-av:copyright>
		<cmns-av:copyright>Copyright (c) 2019-2025 agnos.ai UK Ltd.</cmns-av:copyright>
	</owl:Ontology>
	
	<owl:Class rdf:about="&cmns-lang;ConstructedLanguage">
		<rdfs:subClassOf rdf:resource="&cmns-lang;HumanLanguage"/>
		<rdfs:label>constructed language</rdfs:label>
		<owl:disjointWith rdf:resource="&cmns-lang;FormalLanguage"/>
		<skos:definition>individual language whose rules are explicitly established prior to its use</skos:definition>
		<skos:note>Constructed languages do not include reconstructed languages, computer programming languages, mark-up languages or similar formal languages.</skos:note>
		<skos:note>Some constructed languages are based on one or several natural languages and are therefore not &apos;artificial&apos;.</skos:note>
		<cmns-av:adaptedFrom>ISO 639 Code for individual languages and language groups, Second edition, 2023-11, clause 3.3.2</cmns-av:adaptedFrom>
	</owl:Class>
	
	<owl:Class rdf:about="&cmns-lang;FormalLanguage">
		<rdfs:subClassOf rdf:resource="&cmns-lang;Language"/>
		<rdfs:label>formal language</rdfs:label>
		<skos:definition>language comprised of a set of finite-length strings (i.e., a body of words) constructed from a finite alphabet, following a set of methods of combining them (called a grammar), governed by precise syntactic rules</skos:definition>
		<cmns-av:adaptedFrom>Mateescu, A., Salomaa, A. (1997). Formal Languages: an Introduction and a Synopsis. In: Rozenberg, G., Salomaa, A. (eds) Handbook of Formal Languages. Springer, Berlin, Heidelberg. https://doi.org/10.1007/978-3-642-59136-5_1</cmns-av:adaptedFrom>
		<cmns-av:adaptedFrom>https://mathworld.wolfram.com/FormalLanguage.html</cmns-av:adaptedFrom>
	</owl:Class>
	
	<owl:Class rdf:about="&cmns-lang;HumanLanguage">
		<rdfs:subClassOf rdf:resource="&cmns-lang;Language"/>
		<rdfs:label>human language</rdfs:label>
		<skos:definition>language that may be used to express or communicate meaning or a message between humans</skos:definition>
		<skos:note>Human language was originally developed for, and mainly used in, direct communication between humans. Today its use is increasingly supported by information and communication technologies (ICTs).</skos:note>
		<cmns-av:adaptedFrom>ISO 639 Code for individual languages and language groups, Second edition, 2023-11</cmns-av:adaptedFrom>
	</owl:Class>
	
	<owl:Class rdf:about="&cmns-lang;Language">
		<rdfs:subClassOf rdf:resource="&cmns-col;Arrangement"/>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&cmns-dsg;hasTextualName"/>
				<owl:minCardinality rdf:datatype="&xsd;nonNegativeInteger">0</owl:minCardinality>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&cmns-dsg;hasName"/>
				<owl:onClass rdf:resource="&cmns-dsg;Name"/>
				<owl:minQualifiedCardinality rdf:datatype="&xsd;nonNegativeInteger">0</owl:minQualifiedCardinality>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&cmns-id;isIdentifiedBy"/>
				<owl:onClass rdf:resource="&cmns-lang;LanguageIdentifier"/>
				<owl:minQualifiedCardinality rdf:datatype="&xsd;nonNegativeInteger">0</owl:minQualifiedCardinality>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:label>language</rdfs:label>
		<skos:definition>systematic use of sounds, visual-spatial signs, characters or other written symbols or signs that can be combined to express or communicate meaning, understood by a community</skos:definition>
		<cmns-av:adaptedFrom>ISO 639 Code for individual languages and language groups, Second edition, 2023-11, clause 3.1.1</cmns-av:adaptedFrom>
	</owl:Class>
	
	<owl:Class rdf:about="&cmns-lang;LanguageIdentifier">
		<rdfs:subClassOf rdf:resource="&cmns-cds;CodeElement"/>
		<rdfs:subClassOf rdf:resource="&cmns-id;Identifier"/>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&cmns-dsg;hasTag"/>
				<owl:someValuesFrom rdf:resource="&xsd;string"/>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&cmns-id;identifies"/>
				<owl:someValuesFrom rdf:resource="&cmns-lang;Language"/>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:label>language identifier</rdfs:label>
		<skos:definition>string of characters assigned to an individual language or a language group for the purpose of identifying it unequivocally</skos:definition>
		<skos:scopeNote>In the ISO 639 language code, the string of characters consists of a string of letters.</skos:scopeNote>
		<cmns-av:adaptedFrom>ISO 639 Code for individual languages and language groups, Second edition, 2023-11, clause 3.7.10</cmns-av:adaptedFrom>
		<cmns-av:synonym>language symbol</cmns-av:synonym>
	</owl:Class>
	
	<owl:Class rdf:about="&cmns-lang;NaturalLanguage">
		<rdfs:subClassOf rdf:resource="&cmns-lang;HumanLanguage"/>
		<rdfs:label>natural language</rdfs:label>
		<skos:definition>individual language which is or was in active use in a language community, passed on from one generation of speakers to the next</skos:definition>
		<skos:example>Bambara, English, Haitian Creole, Latin, LIBRAS (Língua Brasileira de Sinais/Brazilian Sign Language)</skos:example>
		<cmns-av:adaptedFrom>ISO 639 Code for individual languages and language groups, Second edition, 2023-11, clause 3.3.1</cmns-av:adaptedFrom>
	</owl:Class>
	
	<owl:Class rdf:about="&cmns-lang;Script">
		<rdfs:subClassOf rdf:resource="&cmns-col;Collection"/>
		<rdfs:label>script</rdfs:label>
		<skos:definition>comprehensive set of graphic characters used for the written form of one or more individual languages</skos:definition>
		<skos:example>Cyrillic, Hiragana</skos:example>
		<skos:note>A script, as opposed to an arbitrary subset of characters, is defined in distinction to other scripts; in general, readers of one script can be unable to read the glyphs of another script easily, even where there is a historical relation between them. ISO 639 language identifiers may be combined with script identifiers from ISO 15924 (e.g., BCP 47).</skos:note>
		<cmns-av:adaptedFrom>ISO 639 Code for individual languages and language groups, Second edition, 2023-11, clause 3.6.2</cmns-av:adaptedFrom>
	</owl:Class>
	
	<owl:Class rdf:about="&cmns-lang;ScriptIdentifier">
		<rdfs:subClassOf rdf:resource="&cmns-cds;CodeElement"/>
		<rdfs:subClassOf rdf:resource="&cmns-id;Identifier"/>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&cmns-dsg;hasTag"/>
				<owl:someValuesFrom rdf:resource="&xsd;string"/>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:subClassOf>
			<owl:Restriction>
				<owl:onProperty rdf:resource="&cmns-id;identifies"/>
				<owl:someValuesFrom rdf:resource="&cmns-lang;Script"/>
			</owl:Restriction>
		</rdfs:subClassOf>
		<rdfs:label>script identifier</rdfs:label>
		<skos:definition>string of characters assigned to represent a script unequivocally</skos:definition>
		<cmns-av:adaptedFrom>ISO 639 Code for individual languages and language groups, Second edition, 2023-11, clause 3.7.10</cmns-av:adaptedFrom>
		<cmns-av:synonym>script symbol</cmns-av:synonym>
	</owl:Class>
	
	<owl:ObjectProperty rdf:about="&cmns-lang;hasLanguage">
		<rdfs:subPropertyOf rdf:resource="&cmns-cxtdsg;uses"/>
		<rdfs:label>has language</rdfs:label>
		<rdfs:range rdf:resource="&cmns-lang;Language"/>
		<skos:definition>is expressed in or uses a given language in some context</skos:definition>
	</owl:ObjectProperty>

</rdf:RDF>