@prefix ex: <https://example.com/entio/simple#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .

ex:CustomerShape
    a sh:NodeShape ;
    sh:targetClass ex:Customer ;
    sh:property ex:CustomerOwnsAccountShape .

ex:CustomerOwnsAccountShape
    sh:path ex:ownsAccount ;
    sh:minCount 1 ;
    sh:message "Each customer must own at least one account." .
